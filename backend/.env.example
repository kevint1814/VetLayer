# VetLayer Environment Configuration
# Copy this to .env and fill in your values

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vetlayer:vetlayer@localhost:5432/vetlayer

# ── LLM Provider ─────────────────────────────────────────────────────
# Options: "groq" (default, fast), "openai" (reliable), "anthropic" (premium)
LLM_PROVIDER=groq

# Groq (Llama 3.3 70B — primary, fast inference)
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# OpenAI (GPT-4o Mini — fallback for JSON reliability)
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Anthropic (Claude — optional, production quality)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Fallback: if primary fails, automatically retry with fallback provider
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_PROVIDER=openai

# ── App Settings ─────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=change-me-in-production
