# VetLayer Environment Configuration
# Copy this to .env and fill in your values

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vetlayer:vetlayer@localhost:5432/vetlayer

# ── LLM Provider ─────────────────────────────────────────────────────
# Options: "openai" (default, cheap) or "anthropic" (production quality)
LLM_PROVIDER=openai

# OpenAI (GPT-4o Mini — default for development)
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Anthropic (Claude — for production)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── App Settings ─────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=change-me-in-production
